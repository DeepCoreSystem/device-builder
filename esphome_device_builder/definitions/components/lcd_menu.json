{"id":"lcd_menu","name":"LCD Menu","description":"The component provides an infrastructure for setting up a hierarchical menu on character based LCD displays. This offers the user an interactive method to display labels, control entities like `switch`, `select`, `number`  available locally on the ESPHome node, without the requirement of a network connection.","category":"misc","docs_url":"https://esphome.io/components/display_menu/lcd_menu","multi_conf":true,"provides":["display_menu_base"],"config_entries":[{"key":"display_id","type":"id","label":"Display ID","description":"Manually specify the ID of the LCD display.","display_format":null,"references_component":"lcd_base","help_link":"https://esphome.io/components/display_menu/lcd_menu#a-debounced-gpio-push-button-is-used-to-click"},{"key":"items","type":"nested","label":"Items","required":true,"display_format":null,"multi_value":true,"config_entries":[{"key":"type","type":"string","label":"Type","required":true,"options":[{"label":"back","value":"back"},{"label":"command","value":"command"},{"label":"custom","value":"custom"},{"label":"label","value":"label"},{"label":"menu","value":"menu"},{"label":"number","value":"number"},{"label":"select","value":"select"},{"label":"switch","value":"switch"}],"display_format":null},{"key":"id","type":"id","label":"ID","required":true,"depends_on":"type","depends_on_value_any":["back","custom","label","menu","number","select","switch"]},{"key":"items","type":"string","label":"Items","required":true,"display_format":null,"multi_value":true,"depends_on":"type","depends_on_value_any":["menu"]},{"key":"number","type":"id","label":"Number","required":true,"display_format":null,"depends_on":"type","references_component":"number","depends_on_value_any":["number"]},{"key":"select","type":"id","label":"Select","required":true,"display_format":null,"depends_on":"type","references_component":"select","depends_on_value_any":["select"]},{"key":"switch","type":"id","label":"Switch","requir