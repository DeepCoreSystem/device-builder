{"id":"output.mcp47a1","name":"MCP47A1 Output","description":"The `mcp47a1` output component allows to use [6bit external DAC](https://www.microchip.com/en-us/product/MCP47A1) in order to have analog output(s) on any board by using I²C. Devices default address is `0x2E` and configurable alternative is `0x3E`.","category":"output","docs_url":"https://esphome.io/components/output/mcp47a1","image_url":"https://esphome.io/images/mcp47a1.svg","dependencies":["i2c"],"multi_conf":true,"config_entries":[{"key":"address","type":"integer","label":"Address","description":"Manually specify the I²C address of the DAC. Defaults to `0x2E`.","default_value":"46","range":[0,255],"display_format":"hex","help_link":"https://esphome.io/components/output/mcp47a1#configuration-variables"},{"key":"i2c_id","type":"id","label":"I2C ID","display_format":null,"references_component":"i2c"},{"key":"inverted","type":"boolean","label":"Inverted","display_format":null},{"key":"id","type":"id","label":"ID","description":"The id to use for this output component.","required":true,"help_link":"https://esphome.io/components/output/mcp47a1#configuration-variables"},{"key":"power_supply","type":"id","label":"Power Supply","display_format":null,"references_component":"power_supply"},{"key":"max_power","type":"string","label":"Max Power","display_format":null,"advanced":true},{"key":"min_power","type":"string","label":"Min Power","display_format":null,"advanced":true},{"key":"setup_priority","type":"float","label":"Setup Priority","display_format":null,"advanced":true,"hidden":true},{"key":"zero_means_zero","type":"boolean","label":"Zero Means Zero","default_value":false,"display_format":null,"advanced":true}]}
