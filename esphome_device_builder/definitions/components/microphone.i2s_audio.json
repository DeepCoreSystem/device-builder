{"id":"microphone.i2s_audio","name":"I²S Audio Microphone","description":"I²S based microphones in ESPHome.","category":"microphone","docs_url":"https://esphome.io/components/microphone/i2s_audio","dependencies":["i2s_audio"],"multi_conf":true,"config_entries":[{"key":"adc_type","type":"string","label":"ADC Type","required":true,"options":[{"label":"external","value":"external"},{"label":"internal","value":"internal"}],"display_format":null},{"key":"adc_pin","type":"pin","label":"ADC Pin","required":true,"display_format":null,"depends_on":"adc_type","pin_features":["adc"],"depends_on_value_any":["internal"]},{"key":"i2s_audio_id","type":"id","label":"I2S Audio ID","description":"The ID of the I²S Audio you wish to use for this microphone.","display_format":null,"references_component":"i2s_audio","help_link":"https://esphome.io/components/microphone/i2s_audio#configuration-variables"},{"key":"i2s_din_pin","type":"pin","label":"I2S Din Pin","required":true,"display_format":null,"depends_on":"adc_type","depends_on_value_any":["external"]},{"key":"id","type":"id","label":"ID","advanced":true},{"key":"bits_per_sample","type":"string","label":"Bits Per Sample","description":"The bit depth of audio samples representing real data received from the microphone. One of 8bit, 16bit, 24bit, or 32bit. Defaults to 32bit.","default_value":"32bit","options":[{"label":"8","value":"8"},{"label":"16","value":"16"},{"label":"24","value":"24"},{"label":"32","value":"32"}],"display_format":null,"advanced":true,"help_link":"https://esphome.io/components/microphone/i2s_audio#configuration-variables"},{"key":"channel","type":"string","label":"Channel","description":"The channel of the microphone. One of left, right, or stereo. If stereo, the output data will be twice as big, with each right sample followed by a left sample. Defaults to right.","default_value":"right","options":[{"label":"mono","value":"mono"},{"label":"left","value":"left"},{"label":"right","value":"right"},{"label":"stereo"