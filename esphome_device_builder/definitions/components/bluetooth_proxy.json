{"id":"bluetooth_proxy","name":"Bluetooth Proxy","description":"Home Assistant can expand its Bluetooth reach by communicating through the Bluetooth proxy component in ESPHome. The individual device integrations in Home Assistant (such as BTHome) will receive the data from the Bluetooth Integration in Home Assistant which automatically aggregates all ESPHome Bluetooth proxies with any USB Bluetooth Adapters you might have. This exceptional feature offers fault tolerant connection between the Bluetooth devices and Home Assistant.","category":"misc","docs_url":"https://esphome.io/components/bluetooth_proxy","dependencies":["api","esp32"],"supported_platforms":["esp32"],"config_entries":[{"key":"id","type":"id","label":"ID","advanced":true},{"key":"active","type":"boolean","label":"Active","default_value":true,"display_format":null,"advanced":true},{"key":"cache_services","type":"boolean","label":"Cache Services","default_value":true,"display_format":null,"advanced":true},{"key":"connection_slots","type":"integer","label":"Connection Slots","default_value":"3","range":[1,9],"display_format":null,"advanced":true},{"key":"connections","type":"nested","label":"Connections","display_format":null,"multi_value":true,"advanced":true,"config_entries":[{"key":"id","type":"id","label":"ID","required":true},{"key":"esp32_ble_id","type":"id","label":"Esp32 BLE ID","display_format":null,"references_component":"esp32_ble_tracker","advanced":true}]},{"key":"esp32_ble_id","type":"id","label":"Esp32 BLE ID","display_format":null,"references_component":"esp32_ble_tracker","advanced":true},{"key":"setup_priority","type":"float","label":"Setup Priority","display_format":null,"advanced":true,"hidden":true}]}
