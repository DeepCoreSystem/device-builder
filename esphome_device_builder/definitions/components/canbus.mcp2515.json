{"id":"canbus.mcp2515","name":"MCP2515","description":"The MCP2515 communicates with ESPHome via the [SPI bus](https://esphome.io/components/spi); to use it, you must have at least one [SPI bus](https://esphome.io/components/spi) with both the `mosi_pin` and `miso_pin` defined in your ESPHome configuration.","category":"canbus","docs_url":"https://esphome.io/components/canbus/mcp2515","image_url":"https://esphome.io/images/mcp2515.svg","dependencies":["spi"],"multi_conf":true,"config_entries":[{"key":"spi_id","type":"id","label":"SPI ID","display_format":null,"references_component":"spi"},{"key":"can_id","type":"integer","label":"Can ID","required":true,"range":[0,536870911],"display_format":null},{"key":"cs_pin","type":"pin","label":"CS Pin","description":"Is used to signal to a SPI device when it should listen for data on the SPI bus. Each SPI device has its own `CS` line. Sometimes also called `SS`.","required":true,"display_format":null,"pin_mode":"output","help_link":"https://esphome.io/components/canbus/mcp2515#configuration-variables","config_entries":[{"key":"mode","type":"nested","label":"Mode","description":"Pin mode flags (input / output / pullup / pulldown / open_drain). Combine flags as needed — e.g. input + pullup for a button pulled to VCC.","display_format":null,"advanced":true,"config_entries":[{"key":"input","type":"boolean","label":"Input","description":"Set the input mode flag.","default_value":false,"display_format":null,"advanced":true},{"key":"output","type":"boolean","label":"Output","description":"Set the output mode flag.","default_value":false,"display_format":null,"advanced":true},{"key":"pullup","type":"boolean","label":"Pullup","description":"Set the pullup mode flag.","default_value":false,"display_format":null,"advanced":true},{"key":"pulldown","type":"boolean","label":"Pulldown","description":"Set the pulldown mode flag.","default_value":false,"display_format":null,"advanced":true},{"key":"open_drain","type":"boolean","label":"Open Drain","description":"Set the open drain mode flag.","default_value":false,"display_format":null,"advanced":true}]},{"key":"inverted","type":"boolean","label":"Inverted","description":"Invert the logical level. ``true`` swaps high/low in software so an active-low button reads as active when grounded.","default_value":false,"display_format":null,"advanced":true}]},{"key":"id","type":"id","label":"ID","advanced":true},{"key":"bit_rate","type":"string","label":"Bit Rate","default_value":"125KBPS","options":[{"label":"1KBPS","value":"1KBPS"},{"label":"5KBPS","value":"5KBPS"},{"label":"10KBPS","value":"10KBPS"},{"label":"12K5BPS","value":"12K5BPS"},{"label":"16KBPS","value":"16KBPS"},{"label":"20KBPS","value":"20KBPS"},{"label":"25KBPS","value":"25KBPS"},{"label":"31K25BPS","value":"31K25BPS"},{"label":"33KBPS","value":"33KBPS"},{"label":"40KBPS","value":"40KBPS"},{"label":"50KBPS","value":"50KBPS"},{"label":"80KBPS","value":"80KBPS"},{"label":"83K3BPS","value":"83K3BPS"},{"label":"95KBPS","value":"95KBPS"},{"label":"100KBPS","value":"100KBPS"},{"label":"125KBPS","value":"125KBPS"},{"label":"200KBPS","value":"200KBPS"},{"label":"250KBPS","value":"250KBPS"},{"label":"500KBPS","value":"500KBPS"},{"label":"800KBPS","value":"800KBPS"},{"label":"1000KBPS","value":"1000KBPS"}],"display_format":null,"advanced":true},{"key":"clock","type":"string","label":"Clock","description":"The frequency of the clock crystal used on the MCP2515 device. One of `8MHZ`, `12MHZ`, `16MHZ` or `20MHZ`. Defaults to `8MHZ`.","default_value":"8MHZ","options":[{"label":"8MHZ","value":"8MHZ"},{"label":"12MHZ","value":"12MHZ"},{"label":"16MHZ","value":"16MHZ"},{"label":"20MHZ","value":"20MHZ"}],"display_format":null,"advanced":true,"help_link":"https://esphome.io/components/canbus/mcp2515#configuration-variables"},{"key":"data_rate","type":"string","label":"Data Rate","display_format":null,"advanced":true},{"key":"mode","type":"string","label":"Mode","description":"Operating mode. One of:","default_value":"NORMAL","options":[{"label":"NORMAL","value":"NORMAL"},{"label":"LOOPBACK","value":"LOOPBACK"},{"label":"LISTENONLY","value":"LISTENONLY"}],"display_format":null,"advanced":true,"help_link":"https://esphome.io/components/canbus/mcp2515#configuration-variables"},{"key":"release_device","type":"boolean","label":"Release Device","display_format":null,"advanced":true,"supported_platforms":["esp32"]},{"key":"setup_priority","type":"float","label":"Setup Priority","display_format":null,"advanced":true,"hidden":true},{"key":"spi_mode","type":"string","label":"SPI Mode","options":[{"label":"MODE0","value":"MODE0"},{"label":"MODE1","value":"MODE1"},{"label":"MODE2","value":"MODE2"},{"label":"MODE3","value":"MODE3"},{"label":"0","value":"0"},{"label":"1","value":"1"},{"label":"2","value":"2"},{"label":"3","value":"3"}],"display_format":null,"advanced":true},{"key":"use_extended_id","type":"boolean","label":"Use Extended ID","default_value":false,"display_format":null,"advanced":true}]}
