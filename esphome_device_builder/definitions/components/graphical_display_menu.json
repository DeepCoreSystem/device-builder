{"id":"graphical_display_menu","name":"Graphical Display Menu","description":"The component provides an infrastructure for setting up a hierarchical menu on graphical displays. This offers the user an interactive method to display labels, control entities like `switch`, `select`, `number`  available locally on the ESPHome node, without the requirement of a network connection.","category":"misc","docs_url":"https://esphome.io/components/display_menu/graphical_display_menu","image_url":"https://esphome.io/images/graphical_display_menu.png","multi_conf":true,"provides":["display_menu_base"],"config_entries":[{"key":"display","type":"id","label":"Display","description":"ID of the display to render to. See [Drawing Modes](https://esphome.io/components/display_menu/graphical_display_menu#drawing_modes) for more details","display_format":null,"references_component":"display","help_link":"https://esphome.io/components/display_menu/graphical_display_menu#example-configuration-entry"},{"key":"font","type":"id","label":"Font","description":"Specifies the font to use","required":true,"display_format":null,"references_component":"font","help_link":"https://esphome.io/components/display_menu/graphical_display_menu#example-configuration-entry"},{"key":"items","type":"nested","label":"Items","required":true,"display_format":null,"multi_value":true,"config_entries":[{"key":"type","type":"string","label":"Type","required":true,"options":[{"label":"back","value":"back"},{"label":"command","value":"command"},{"label":"custom","value":"custom"},{"label":"label","value":"label"},{"label":"menu","value":"menu"},{"label":"number","value":"number"},{"label":"select","value":"select"},{"label":"switch","value":"switch"}],"display_format":null},{"key":"id","type":"id","label":"ID","required":true,"depends_on":"type","depends_on_value_not":"command"},{"key":"items","type":"string","label":"Items","required":true,"display_format":null,"multi_value":true,"depends_on":"type","depends_on_value":"m