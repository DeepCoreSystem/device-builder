{"id":"msa3xx","name":"MSA301 and MSA311 Sensors","description":"The `msa3xx` sensor platform allows you to use your MSA301 and MSA311 tri-axial, low-g accelerometers ([datasheet](https://cdn-shop.adafruit.com/product-files/5309/MSA311-V1.1-ENG.pdf)) with ESPHome. The [I²C](https://esphome.io/components/i2c) is required to be set up in your configuration for this sensor to work.","category":"misc","docs_url":"https://esphome.io/components/sensor/msa3xx","dependencies":["i2c"],"multi_conf":true,"config_entries":[{"key":"type","type":"string","label":"Type","required":true,"options":[{"label":"MSA301","value":"MSA301"},{"label":"MSA311","value":"MSA311"}],"display_format":null},{"key":"address","type":"integer","label":"Address","default_value":"38","range":[0,255],"display_format":"hex","depends_on":"type","depends_on_value_any":["MSA301"]},{"key":"address","type":"integer","label":"Address","default_value":"98","range":[0,255],"display_format":"hex","depends_on":"type","depends_on_value_any":["MSA311"]},{"key":"i2c_id","type":"id","label":"I2C ID","display_format":null,"references_component":"i2c"},{"key":"update_interval","type":"time_period","label":"Update Interval","description":"The interval for updating acceleration sensors. Defaults to `10s`.","default_value":"10s","display_format":null,"help_link":"https://esphome.io/components/sensor/msa3xx#configuration-variables"},{"key":"id","type":"id","label":"ID","advanced":true},{"key":"calibration","type":"nested","label":"Calibration","display_format":null,"advanced":true,"config_entries":[{"key":"offset_x","type":"float","label":"Offset X","default_value":"0","range":[-4.5,4.5],"display_format":null,"advanced":true},{"key":"offset_y","type":"float","label":"Offset Y","default_value":"0","range":[-4.5,4.5],"display_format":null,"advanced":true},{"key":"offset_z","type":"float","label":"Offset Z","default_value":"0","range":[-4.5,4.5],"display_format":null,"advanced":true}]},{"key":"range","type":"string","label":"Range","description":"The range of the sensor measurements. One of `2G`, `4G`, `8G`, `16G`. Defaults to `2G` which means it picks up accelerations between `-2g` and `2g`.","default_value":"2G","options":[{"label":"2G","value":"2G"},{"label":"4G","value":"4G"},{"label":"8G","value":"8G"},{"label":"16G","value":"16G"}],"display_format":null,"advanced":true,"help_link":"https://esphome.io/components/sensor/msa3xx#configuration-variables"},{"key":"resolution","type":"string","label":"Resolution","description":"The ADC resolution of the sensor in bits. Supported values for `msa301` are `8`, `10`, `12`, `14` (*default*). For `msa311` the only resolution supported is `12` (and it is *default*).","default_value":"14","options":[{"label":"14","value":"14"},{"label":"12","value":"12"},{"label":"10","value":"10"},{"label":"8","value":"8"}],"display_format":null,"depends_on":"type","advanced":true,"help_link":"https://esphome.io/components/sensor/msa3xx#configuration-variables","depends_on_value_any":["MSA301"]},{"key":"resolution","type":"string","label":"Resolution","description":"The ADC resolution of the sensor in bits. Supported values for `msa301` are `8`, `10`, `12`, `14` (*default*). For `msa311` the only resolution supported is `12` (and it is *default*).","default_value":"12","options":[{"label":"12","value":"12"}],"display_format":null,"depends_on":"type","advanced":true,"help_link":"https://esphome.io/components/sensor/msa3xx#configuration-variables","depends_on_value_any":["MSA311"]},{"key":"setup_priority","type":"float","label":"Setup Priority","display_format":null,"advanced":true,"hidden":true},{"key":"transform","type":"nested","label":"Transform","display_format":null,"advanced":true,"config_entries":[{"key":"mirror_x","type":"boolean","label":"Mirror X","default_value":false,"display_format":null,"advanced":true},{"key":"mirror_y","type":"boolean","label":"Mirror Y","default_value":false,"display_format":null,"advanced":true},{"key":"mirror_z","type":"boolean","label":"Mirror Z","default_value":false,"display_format":null,"advanced":true},{"key":"swap_xy","type":"boolean","label":"Swap Xy","default_value":false,"display_format":null,"advanced":true}]}]}
