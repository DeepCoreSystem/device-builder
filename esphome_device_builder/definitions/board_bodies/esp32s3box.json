{"description":"Espressif ESP32-S3-Box-3 AIoT dev kit: a 2.4\" 320x240 ILI9341 SPI display with GT911 capacitive touch, dual-mic array, speaker and IMU. The recommended setup covers the display + backlight + touch; the audio path (I2S mics/speaker + the ES8311/ES7210 codec on I2C 8/18) is left for a manual voice-assistant build. ESPHome ships one board id (esp32s3box) for the whole S3-Box family — the display + backlight also fit the original ESP32-S3-Box, but that model uses a TT21100 touch controller, so the GT911 Touchscreen bundle is Box-3 only.","docs_url":"https://github.com/espressif/esp-box","esphome":{"board":"esp32s3box","framework":"esp-idf","platform":"esp32","variant":"esp32s3"},"featured_bundles":[{"component_ids":["lcd_spi","lcd_display","backlight_output","display_backlight"],"id":"display_setup","name":"Display (full setup)"},{"component_ids":["i2c_bus","lcd_touch","backlight_output","display_backlight"],"id":"touchscreen_setup","name":"Touchscreen (full setup)"}],"featured_components":[{"component_id":"spi","fields":{"clk_pin":{"locked":true,"value":7},"id":{"locked":true,"value":"lcd_spi"},"mosi_pin":{"locked":true,"value":6}},"id":"lcd_spi","locked_pins":{"clk_pin":7,"mosi_pin":6}},{"component_id":"i2c","fields":{"id":{"locked":true,"value":"i2c_bus"},"scan":{"value":true},"scl":{"locked":true,"value":18},"sda":{"locked":true,"value":8}},"id":"i2c_bus","locked_pins":{"scl":18,"sda":8}},{"component_id":"display.mipi_spi","fields":{"cs_pin":{"locked":true,"value":5},"dc_pin":{"locked":true,"value":4},"id":{"value":"lcd_display"},"model":{"value":"S3BOX"},"reset_pin":{"locked":true,"value":{"inverted":true,"number":48}},"show_test_card":{"value":true},"spi_id":{"locked":true,"value":"lcd_spi"}},"id":"lcd_display","locked_pins":{"cs_pin":5,"dc_pin":4,"reset_pin":48},"requires":["lcd_spi"]},{"component_id":"output.ledc","fields":{"frequency":{"value":"1000Hz"},"id":{"value":"backlight_output"},"pin":{"locked":true,"value":47}},"id":"backlight_output",