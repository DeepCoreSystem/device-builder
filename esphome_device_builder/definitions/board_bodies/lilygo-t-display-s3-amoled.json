{"description":"LILYGO T-Display-S3-AMOLED: an ESP32-S3 board with a 1.91\" 240x536 RM67162 AMOLED panel driven over a quad-SPI (QSPI) bus. The panel is self-emissive, so there is no backlight output; brightness is set through the display. GPIO38 enables the panel power rail. GPIO21 is a user button on non-touch units and the CST816 touch interrupt on touch units, so it is left free to assign.","docs_url":"https://github.com/Xinyuan-LilyGO/T-Display-S3-AMOLED","esphome":{"board":"esp32-s3-devkitc-1","framework":"esp-idf","platform":"esp32","variant":"esp32s3"},"featured_bundles":[{"component_ids":["lcd_spi","lcd_display"],"id":"display_setup","name":"Display (full setup)"}],"featured_components":[{"component_id":"spi","fields":{"clk_pin":{"locked":true,"value":47},"data_pins":{"locked":true,"value":[18,7,48,5]},"id":{"locked":true,"value":"lcd_spi"},"type":{"value":"quad"}},"id":"lcd_spi","locked_pins":{"clk_pin":47}},{"component_id":"display.mipi_spi","fields":{"cs_pin":{"locked":true,"value":6},"id":{"value":"lcd_display"},"model":{"value":"T-DISPLAY-S3-AMOLED"},"reset_pin":{"locked":true,"value":17},"show_test_card":{"value":true},"spi_id":{"locked":true,"value":"lcd_spi"}},"id":"lcd_display","locked_pins":{"cs_pin":6,"reset_pin":17},"requires":["lcd_spi"]},{"component_id":"binary_sensor.gpio","fields":{"id":{"value":"boot_button"},"name":{"value":"BOOT Button"},"pin":{"locked":true,"value":{"ignore_strapping_warning":true,"inverted":true,"number":0}}},"id":"boot_button","locked_pins":{"pin":0}}],"hardware":{"connectivity":["wifi","bluetooth"],"flash_size":"16MB"},"id":"lilygo-t-display-s3-amoled","images":["https://raw.githubusercontent.com/Xinyuan-LilyGO/T-Display-S3-AMOLED/main/image/T-Display-S3-AMOLED.jpg"],"manufacturer":"LILYGO","name":"LILYGO T-Display-S3-AMOLED","pins":[{"available":false,"gpio":0,"label":"GPIO0","notes":"BOOT button (strapping pin, active low)","occupied_by":"boot_button"},{"gpio":4,"label":"GPIO4","notes":"Battery voltage ADC (on-board 1:2 divider)"},{"available":false,"gpio":5,"label":"GPIO5","notes":"Display QSPI data3","occupied_by":"lcd_spi"},{"available":false,"gpio":6,"label":"GPIO6","notes":"Display CS","occupied_by":"lcd_display"},{"available":false,"gpio":7,"label":"GPIO7","notes":"Display QSPI data1","occupied_by":"lcd_spi"},{"available":false,"gpio":17,"label":"GPIO17","notes":"Display reset","occupied_by":"lcd_display"},{"available":false,"gpio":18,"label":"GPIO18","notes":"Display QSPI data0","occupied_by":"lcd_spi"},{"gpio":21,"label":"GPIO21","notes":"User button on non-touch units, CST816 touch interrupt on touch units"},{"available":false,"gpio":38,"label":"GPIO38","notes":"AMOLED power enable","occupied_by":"lcd_display"},{"available":false,"features":["spi_clk"],"gpio":47,"label":"GPIO47","notes":"Display QSPI clock","occupied_by":"lcd_spi"},{"available":false,"gpio":48,"label":"GPIO48","notes":"Display QSPI data2","occupied_by":"lcd_spi"}],"tags":["display"]}
