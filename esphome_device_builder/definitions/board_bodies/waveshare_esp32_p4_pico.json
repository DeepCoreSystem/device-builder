{"default_components":[{"id":"c6_wifi"}],"description":"Waveshare ESP32-P4-Pico in the Raspberry Pi Pico form factor with the ESP32-P4NRW32 (dual-core RISC-V @ 400MHz, 32MB flash, 32MB PSRAM) and an onboard ESP32-C6 co-processor. The ESP32-P4 has no built-in radio; Wi-Fi 6 works out of the box through the onboard ESP32-C6 co-processor. MIPI DSI display and MIPI CSI camera connectors, microSD slot, microphone + speaker header, USB-C port plus 4-pin USB OTG header, 27 user GPIOs.","docs_url":"https://www.waveshare.com/wiki/ESP32-P4-Pico","esphome":{"board":"esp32-p4-evboard","framework":"esp-idf","platform":"esp32","variant":"esp32p4"},"featured_components":[{"component_id":"esp32_hosted","description":"Onboard ESP32-C6 running ESP-Hosted over SDIO gives the radio-less ESP32-P4 Wi-Fi 6. Installed automatically in every new device — the wifi block only works while this is present. If the C6 never comes up on your unit, try active_high false.","fields":{"active_high":{"value":true},"clk_pin":{"locked":true,"value":"GPIO18"},"cmd_pin":{"locked":true,"value":"GPIO19"},"d0_pin":{"locked":true,"value":"GPIO14"},"d1_pin":{"locked":true,"value":"GPIO15"},"d2_pin":{"locked":true,"value":"GPIO16"},"d3_pin":{"locked":true,"value":"GPIO17"},"reset_pin":{"locked":true,"value":"GPIO54"},"type":{"locked":true,"value":"sdio"},"variant":{"locked":true,"value":"ESP32C6"}},"id":"c6_wifi","locked_pins":{"clk_pin":18,"cmd_pin":19,"d0_pin":14,"d1_pin":15,"d2_pin":16,"d3_pin":17,"reset_pin":54},"multi_conf":false,"name":"Wi-Fi via ESP32-C6 co-processor"}],"hardware":{"connectivity":["wifi"],"cpu_frequency":"400MHz","flash_size":"32MB"},"id":"waveshare_esp32_p4_pico","images":["https://www.waveshare.com/media/catalog/product/cache/1/image/800x800/9df78eab33525d08d6e5fb8d27136e95/e/s/esp32-p4-pico-1.jpg"],"manufacturer":"Waveshare","name":"Waveshare ESP32-P4-Pico","pins":[{"features":["pwm"],"gpio":0,"label":"GPIO0"},{"features":["pwm"],"gpio":1,"label":"GPIO1"},{"features":["pwm","touch"],"g