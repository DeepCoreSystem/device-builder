{"description":"GeekMagic SmallTV Pro: an ESP32 desktop smart-display cube with a 1.54\" 240x240 ST7789 SPI LCD. The display runs on the ESP32 SPI bus (CLK GPIO18, MOSI GPIO23) with DC on GPIO2 (a strapping pin, handled with ignore_strapping_warning) and reset on GPIO4; CS is tied to ground. The backlight (GPIO25) is active-low, driven by an inverted PWM output. This is the ESP32 SmallTV Pro, not the original ESP8266 SmallTV.","docs_url":"https://esphome.io/components/display/mipi_spi/","esphome":{"board":"esp32dev","framework":"esp-idf","platform":"esp32","variant":"esp32"},"featured_bundles":[{"component_ids":["lcd_spi","lcd_display","backlight_output","display_backlight"],"id":"display_setup","name":"Display (full setup)"}],"featured_components":[{"component_id":"spi","fields":{"clk_pin":{"locked":true,"value":18},"id":{"locked":true,"value":"lcd_spi"},"mosi_pin":{"locked":true,"value":23}},"id":"lcd_spi","locked_pins":{"clk_pin":18,"mosi_pin":23}},{"component_id":"display.mipi_spi","fields":{"dc_pin":{"locked":true,"value":{"ignore_strapping_warning":true,"number":2}},"id":{"value":"lcd_display"},"model":{"value":"GEEKMAGIC-SMALLTV-PRO"},"reset_pin":{"locked":true,"value":4},"show_test_card":{"value":true},"spi_id":{"locked":true,"value":"lcd_spi"}},"id":"lcd_display","locked_pins":{"dc_pin":2,"reset_pin":4},"requires":["lcd_spi"]},{"component_id":"output.ledc","fields":{"frequency":{"value":"1000Hz"},"id":{"value":"backlight_output"},"inverted":{"value":true},"pin":{"locked":true,"value":25}},"id":"backlight_output","locked_pins":{"pin":25}},{"component_id":"light.monochromatic","fields":{"icon":{"value":"mdi:brightness-7"},"id":{"value":"display_backlight"},"name":{"value":"Display Backlight"},"output":{"value":"backlight_output"},"restore_mode":{"value":"ALWAYS_ON"}},"id":"display_backlight","requires":["backlight_output"]}],"hardware":{"connectivity":["wifi","bluetooth"],"flash_size":"4MB"},"id":"geekmagic_smalltv_pro","images":["/boards/images/_generic/esp3