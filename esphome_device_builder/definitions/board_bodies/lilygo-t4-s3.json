{"description":"LILYGO T4-S3: an ESP32-S3 board with a 2.41\" 450x600 RM690B0 AMOLED panel driven over a quad-SPI (QSPI) bus. The panel is self-emissive, so there is no backlight; brightness is set through the display. GPIO9 enables the panel power rail and is supplied by the model. The board also carries a CST226SE touch panel and a PMU on a shared I2C bus (SDA GPIO6 / SCL GPIO7), left free to assign.","docs_url":"https://github.com/Xinyuan-LilyGO/LilyGo-AMOLED-Series","esphome":{"board":"esp32-s3-devkitc-1","framework":"esp-idf","platform":"esp32","variant":"esp32s3"},"featured_bundles":[{"component_ids":["lcd_spi","lcd_display"],"id":"display_setup","name":"Display (full setup)"}],"featured_components":[{"component_id":"spi","fields":{"clk_pin":{"locked":true,"value":15},"data_pins":{"locked":true,"value":[14,10,16,12]},"id":{"locked":true,"value":"lcd_spi"},"type":{"value":"quad"}},"id":"lcd_spi","locked_pins":{"clk_pin":15}},{"component_id":"display.mipi_spi","fields":{"cs_pin":{"locked":true,"value":11},"id":{"value":"lcd_display"},"model":{"value":"T4-S3"},"reset_pin":{"locked":true,"value":13},"show_test_card":{"value":true},"spi_id":{"locked":true,"value":"lcd_spi"}},"id":"lcd_display","locked_pins":{"cs_pin":11,"reset_pin":13},"requires":["lcd_spi"]},{"component_id":"binary_sensor.gpio","fields":{"id":{"value":"boot_button"},"name":{"value":"BOOT Button"},"pin":{"locked":true,"value":{"ignore_strapping_warning":true,"inverted":true,"number":0}}},"id":"boot_button","locked_pins":{"pin":0}}],"hardware":{"connectivity":["wifi","bluetooth"],"flash_size":"16MB"},"id":"lilygo-t4-s3","images":["https://raw.githubusercontent.com/Xinyuan-LilyGO/LilyGo-AMOLED-Series/master/shell/images/T4-S3-AMOLED.png"],"manufacturer":"LILYGO","name":"LILYGO T4-S3","pins":[{"available":false,"gpio":0,"label":"GPIO0","notes":"BOOT button (strapping pin, active low)","occupied_by":"boot_button"},{"gpio":6,"label":"GPIO6","notes":"Touch/PMU I2C SDA (CST226SE + power management)"},{"gp